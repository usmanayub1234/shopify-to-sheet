# ============================================================
#  .env.example  —  copy to .env.local for local dev
#  Add ALL of these in Vercel → Project → Settings → Environment Variables
# ============================================================

# ── SHOPIFY ──────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# ── GOOGLE SHEETS ────────────────────────────────────────────
GOOGLE_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_SHEET_TAB_NAME=Shopify Products

# ── GOOGLE SERVICE ACCOUNT ───────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=shopify-sync@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# ── SECURITY ─────────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=replace_with_a_long_random_secret_string
